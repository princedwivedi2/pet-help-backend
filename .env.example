APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Set to true ONLY in local development. Leaks stack traces + config in error responses.
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Payment Gateway (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- CORS ---
# Dev default already includes localhost:3000/3001/3002 — override for production:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- App Key ---
# Run: php artisan key:generate
# APP_KEY must be set before any encrypted value works (sessions, cookies)

# --- Queue (dev: sync avoids needing queue worker) ---
# QUEUE_CONNECTION=sync

# --- Mail ---
# MAIL_MAILER=log    — emails written to storage/logs (default, dev only)
# MAIL_MAILER=smtp   — requires MAIL_HOST, MAIL_PORT, MAIL_USERNAME, MAIL_PASSWORD
# MAIL_MAILER=mailgun — requires MAILGUN_DOMAIN, MAILGUN_SECRET

# --- Push Notifications (Firebase Cloud Messaging) ---
# Get from Firebase Console > Project Settings > Cloud Messaging
FCM_SERVER_KEY=

# --- AI Chatbot (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Real-time Broadcasting (Laravel Reverb) ---
# Run: php artisan reverb:install  then  php artisan reverb:start
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
